# Anime Hub environment (installed as /etc/anime-hub.env)
APP_DIR=/opt/anime-hub
DOWNLOAD_DIR=/home/share
WEB_PORT=8765
ARIA2_RPC_PORT=6800
ARIA2_RPC_SECRET=animehub

# File Browser
FILEBROWSER_PORT=8080
FILEBROWSER_USER=admin
# Leave empty to auto-generate a random password on first install
FILEBROWSER_PASSWORD=
FILEBROWSER_ROOT=/home/share
